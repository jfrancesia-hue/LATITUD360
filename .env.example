# ─────────────────────────────────────────────────────────────────
# LATITUD360 — variables de entorno
# Copiar a .env.local en cada app que las necesite. NUNCA commitear.
# ─────────────────────────────────────────────────────────────────

# ─── Database (Supabase project NUEVO para Latitud360, no reutilizar) ───
DATABASE_URL="postgresql://postgres:PASS@db.PROJECT_REF.supabase.co:5432/postgres?schema=public"
DIRECT_URL="postgresql://postgres:PASS@db.PROJECT_REF.supabase.co:5432/postgres"

# ─── Supabase Auth + Storage ───
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGc..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGc..."   # solo backend

# ─── IA híbrida (Claude principal + OpenAI embeddings) ───
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-4-6"
OPENAI_API_KEY="sk-..."
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# ─── Notificaciones ───
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="alertas@latitud360.com"
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
EXPO_ACCESS_TOKEN=""   # para push notifications

# ─── Payments ───
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
MERCADOPAGO_ACCESS_TOKEN="APP_USR-..."
MERCADOPAGO_PUBLIC_KEY="APP_USR-..."

# ─── Storage ───
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="latitud360-prod"
R2_PUBLIC_URL="https://media.latitud360.com"

# ─── Monitoring ───
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.posthog.com"

# ─── App ───
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_DEFAULT_TENANT="demo"
NEXTAUTH_SECRET="generar-con-openssl-rand-base64-32"

# ─── Multi-tenant ───
ROOT_DOMAIN="latitud360.com"   # en local: localhost:3000
ALLOW_TENANT_REGISTRATION="false"

# ─── Seguridad ───
RATE_LIMIT_RPM="100"
ENCRYPTION_KEY="generar-con-openssl-rand-hex-32"
JWT_SECRET="generar-con-openssl-rand-base64-64"
