# Copiar a .env.local

PORT=3001
NODE_ENV=development

DATABASE_URL="postgresql://postgres:PASS@db.PROJECT_REF.supabase.co:5432/postgres?schema=public"
DIRECT_URL="postgresql://postgres:PASS@db.PROJECT_REF.supabase.co:5432/postgres"

ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-4-6"
OPENAI_API_KEY="sk-..."
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

RATE_LIMIT_RPM=100
JWT_SECRET="reemplazar-con-openssl-rand-base64-64"

# Solo para llamadas server-side, NO para cliente
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
