{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "name": "latitud360",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security",  "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Frame-Options",            "value": "DENY" },
        { "key": "X-Content-Type-Options",     "value": "nosniff" },
        { "key": "Referrer-Policy",            "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",         "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" },
        { "key": "Content-Security-Policy",    "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.tailwindcss.com https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.tailwindcss.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; media-src 'self' blob: https:; connect-src 'self' https:; frame-ancestors 'none'; base-uri 'self'; form-action 'self' mailto:" }
      ]
    },
    {
      "source": "/videos/(.*\\.mp4)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Content-Type",  "value": "video/mp4" }
      ]
    },
    {
      "source": "/(.*\\.(?:woff2|woff|ttf|otf))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "redirects": [
    { "source": "/demo",          "destination": "mailto:demo@latitud360.com?subject=Demo%20Latitud360", "permanent": false },
    { "source": "/app",           "destination": "https://app.latitud360.com",                          "permanent": false },
    { "source": "/minera360",     "destination": "https://minera360.com",                               "permanent": false },
    { "source": "/latitud",       "destination": "https://latitud.minera",                              "permanent": false }
  ]
}
