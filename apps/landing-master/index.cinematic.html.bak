            text="Construido para la realidad del NOA"
            className="font-heading italic text-artico text-5xl md:text-6xl lg:text-[5.5rem] heading-lg"
          />
        </div>

        <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mt-16">
          {industries.map(({ name, chipTint, stat, bg }) => (
            <div key={name}
                 className="relative rounded-[1.25rem] overflow-hidden min-h-[400px] flex flex-col justify-end group">
              {/* Background gradient (cuando no hay imagen) */}
              <div className={"absolute inset-0 bg-gradient-to-br " + bg} />
              <div className="absolute inset-0 bg-gradient-to-t from-black via-black/60 to-transparent" />

              {/* Content */}
              <div className="relative z-10 p-5 liquid-glass rounded-t-none">
                <span className="liquid-glass rounded-full px-2.5 py-0.5 text-[11px] font-body text-artico inline-block mb-3">
                  {name}
                </span>
                <h3 className="font-heading italic text-artico text-4xl leading-none">{name}</h3>
                <p className={"mt-3 font-mono text-[11px] " + chipTint + "/90 leading-snug"}>
                  {stat}
                </p>
                <a href="#cta"
                   className="mt-4 inline-flex items-center gap-1.5 text-xs font-medium text-artico hover:text-white">
                  Casos de uso <I.ArrowUpRight className="h-3.5 w-3.5" />
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  );
};
window.Section4Industries = Section4Industries;
</script>

<!-- ════════════════════════════════════════════════════════════════ -->
<!--  SECCIÓN 5 — CASOS Y CLIENTES                                     -->
<!-- ════════════════════════════════════════════════════════════════ -->
<script type="text/babel">
const Section5Cases = () => {
  const { BlurText, I } = window;
  const { motion } = window.Motion;

  const logos = [
    "Livent", "Eramet", "Ganfeng", "Allkem",
    "CAEM", "CAMYEN", "Min. Minería Catamarca", "Repsol Fondo",
  ];

  return (
    <section id="casos" className="cinema bg-mina grain">
      <div className="bg-layer">
        <div className="absolute inset-0 bg-gradient-to-b from-mina via-[#080808] to-mina" />
        <div className="absolute top-1/3 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full bg-naranja/[0.04] blur-3xl pointer-events-none" />
      </div>

      <div className="content-layer px-6 md:px-12 lg:px-20 py-24 lg:py-32 max-w-7xl mx-auto">

        <div className="text-center max-w-3xl mx-auto">
          <p className="font-mono text-xs text-artico/70 tracking-[0.2em] uppercase mb-6">// Confianza</p>
          <BlurText
            text="Trabajamos con quienes mueven el NOA"
            className="font-heading italic text-artico text-4xl md:text-5xl lg:text-6xl heading-lg"
          />
          <p className="mt-4 text-xs font-mono text-artico/50 tracking-wider uppercase">
            En conversaciones con
          </p>
        </div>

        {/* Logos */}
        <div className="mt-12 grid grid-cols-2 md:grid-cols-4 gap-4">
          {logos.map((logo, i) => (
            <motion.div key={logo}
              initial={{ opacity: 0, y: 12 }}
              whileInView={{ opacity: 1, y: 0 }}
              viewport={{ once: true, amount: 0.2 }}
              transition={{ delay: i * 0.05, duration: 0.5 }}
              className="liquid-glass rounded-2xl h-20 flex items-center justify-center text-artico/70 font-heading italic text-xl hover:text-white transition-colors">
              {logo}
            </motion.div>
          ))}
        </div>

        {/* Testimonial */}
        <motion.div
          initial={{ opacity: 0, y: 30, filter: 'blur(8px)' }}
          whileInView={{ opacity: 1, y: 0, filter: 'blur(0px)' }}
          viewport={{ once: true, amount: 0.3 }}
          transition={{ duration: 0.8, ease: 'easeOut' }}
          className="mt-20 liquid-glass-strong rounded-[1.5rem] p-8 md:p-12 max-w-3xl mx-auto">
          <div className="flex flex-col md:flex-row items-start gap-6">
            <div className="w-20 h-20 shrink-0 rounded-full bg-gradient-to-br from-naranja via-dorado to-turquesa p-[2px]">
              <div className="w-full h-full rounded-full bg-mina flex items-center justify-center font-heading italic text-3xl text-artico">
                JF
              </div>
            </div>
            <div>
              <p className="font-heading italic text-artico text-2xl md:text-3xl leading-snug">
                "Estamos construyendo desde Catamarca la infraestructura digital que toda la minería del NOA necesita. Latitud360 no es un software más: es el operating system del sector."
              </p>
              <div className="mt-5 font-body text-sm">
                <div className="text-artico font-medium">Jorge Eduardo Francesia</div>
                <div className="text-artico/60">Founder &amp; CEO, Nativos Consultora Digital</div>
              </div>
            </div>
          </div>
        </motion.div>
      </div>
    </section>
  );
};
window.Section5Cases = Section5Cases;
</script>

<!-- ════════════════════════════════════════════════════════════════ -->
<!--  SECCIÓN 6 — CTA FINAL + FOOTER                                   -->
<!-- ════════════════════════════════════════════════════════════════ -->
<script type="text/babel">
const Section6CTAFooter = () => {
  const { FadingVideo, BlurText, I } = window;
  const { motion } = window.Motion;

  const cols = [
    { title: "PRODUCTOS",  links: ["Minera360", "Latitud", "Contacto", "Toori"] },
    { title: "PLATAFORMA", links: ["Seguridad", "Compliance", "API", "Estado"] },
    { title: "EMPRESA",    links: ["Nosotros", "Equipo", "Carreras", "Prensa"] },
    { title: "LEGAL",      links: ["Privacidad", "Términos", "Cookies"] },
  ];

  return (
    <section id="cta" className="cinema mesh-atardecer mesh-anim grain">
      <div className="bg-layer">
        <FadingVideo src="videos/05-atardecer.mp4"
          className="absolute inset-0 w-full h-full object-cover" />
        <div className="absolute inset-0 bg-black/30" />
      </div>

      <div className="content-layer flex flex-col min-h-screen">

        {/* CTA */}
        <div className="flex-1 flex flex-col items-center justify-center text-center px-6 pt-32 pb-16">

          <motion.div
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true, amount: 0.3 }}
            transition={{ duration: 0.7 }}
            className="liquid-glass rounded-full px-3.5 py-1.5 text-[11px] font-mono uppercase tracking-[0.2em] text-artico/85">
            Para mineras del Triángulo del Litio
          </motion.div>

          <BlurText
            text="Tu próxima revolución operativa empieza acá."
            className="mt-8 font-heading italic text-artico text-5xl md:text-6xl lg:text-[6.5rem] heading-xl max-w-5xl"
          />

          <motion.p
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true, amount: 0.3 }}
            transition={{ duration: 0.7, delay: 0.6 }}
            className="mt-8 text-base md:text-lg text-artico/85 font-body font-light max-w-2xl">
            Agendá una demo personalizada con nuestro equipo. 30 minutos. Sin compromiso. Te mostramos exactamente cómo Latitud360 se aplicaría a tu operación.
          </motion.p>

          <motion.a
            href="mailto:demo@latitud360.com?subject=Demo%20Latitud360"
            initial={{ opacity: 0, scale: 0.95 }}
            whileInView={{ opacity: 1, scale: 1 }}
            viewport={{ once: true, amount: 0.3 }}
            transition={{ duration: 0.7, delay: 0.8 }}
            whileHover={{ scale: 1.03 }}
            className="mt-12 liquid-glass-strong rounded-full px-8 py-4 inline-flex items-center gap-3 text-base md:text-lg font-medium text-white">
            Solicitar demo
            <I.ArrowUpRight className="h-5 w-5" />
          </motion.a>

          <motion.p
            initial={{ opacity: 0 }}
            whileInView={{ opacity: 1 }}
            viewport={{ once: true, amount: 0.3 }}
            transition={{ duration: 0.7, delay: 1 }}
            className="mt-12 font-heading italic text-artico/70 text-xl md:text-2xl tracking-tight">
            Catamarca · Argentina · 2026
          </motion.p>
        </div>

        {/* Footer */}
        <footer className="liquid-glass border-t border-white/5 px-6 md:px-12 lg:px-20 py-12">
          <div className="max-w-7xl mx-auto">

            {/* Top */}
            <div className="flex flex-col md:flex-row md:items-end md:justify-between gap-6 pb-8 border-b border-white/5">
              <div>
                <div className="font-heading italic text-artico text-4xl tracking-tight">Latitud360</div>
                <div className="font-body text-sm text-artico/60 mt-1">Una latitud. Todas tus operaciones.</div>
              </div>
              <div className="flex items-center gap-3">
                <a href="https://linkedin.com" aria-label="LinkedIn"
                   className="liquid-glass w-10 h-10 rounded-full flex items-center justify-center text-artico/70 hover:text-white">
                  <I.LinkedIn className="h-4 w-4" />
                </a>
                <a href="https://x.com" aria-label="X"
                   className="liquid-glass w-10 h-10 rounded-full flex items-center justify-center text-artico/70 hover:text-white">
                  <I.X className="h-4 w-4" />
                </a>
                <a href="https://youtube.com" aria-label="YouTube"
                   className="liquid-glass w-10 h-10 rounded-full flex items-center justify-center text-artico/70 hover:text-white">
                  <I.YouTube className="h-4 w-4" />
                </a>
                <a href="https://instagram.com" aria-label="Instagram"
                   className="liquid-glass w-10 h-10 rounded-full flex items-center justify-center text-artico/70 hover:text-white">
                  <I.Instagram className="h-4 w-4" />
                </a>
              </div>
            </div>

            {/* Cols */}
            <div className="grid grid-cols-2 md:grid-cols-4 gap-8 py-10">
              {cols.map(({ title, links }) => (
                <div key={title}>
                  <div className="font-mono text-[10px] tracking-[0.2em] text-artico/50 uppercase mb-4">{title}</div>
                  <ul className="space-y-2.5">
                    {links.map(l => (
                      <li key={l}>
                        <a href="#" className="text-sm font-body text-artico/85 hover:text-white">{l}</a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>

            {/* Bottom */}
            <div className="flex flex-col md:flex-row items-start md:items-center justify-between gap-3 pt-8 border-t border-white/5 text-xs font-mono text-artico/50">
              <div>© 2026 Nativos Consultora Digital — Catamarca, Argentina</div>
              <div className="tracking-wider uppercase">Built in Catamarca · Latitud −28.4696 · Longitud −65.7795</div>
            </div>
          </div>
        </footer>
      </div>
    </section>
  );
};
window.Section6CTAFooter = Section6CTAFooter;
</script>

