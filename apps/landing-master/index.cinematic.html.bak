<!--  APP root + render                                                -->
<!-- ════════════════════════════════════════════════════════════════ -->
<script type="text/babel">
const App = () => {
  const { Navbar, Section1Hero, Section2Products, Section3Copilot,
          Section4Industries, Section5Cases, Section6CTAFooter } = window;
  return (
    <main>
      <Navbar />
      <Section1Hero />
      <Section2Products />
      <Section3Copilot />
      <Section4Industries />
      <Section5Cases />
      <Section6CTAFooter />
    </main>
  );
};

const root = ReactDOM.createRoot(document.getElementById('root'));
root.render(<App />);
</script>

